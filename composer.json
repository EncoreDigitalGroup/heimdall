{
    "name": "encoredigitalgroup/heimdall",
    "description": "Heimdall — a Composer plugin that guards the bridge between Packagist and your vendor directory against supply chain attacks.",
    "type": "composer-plugin",
    "license": "BSD-3-Clause",
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "require": {
        "php": "^8.4",
        "composer-plugin-api": "^2.0",
        "encoredigitalgroup/stdlib": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.8",
        "friendsofphp/php-cs-fixer": "^3.92",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4",
        "phpgenesis/common": "^1.0",
        "phpgenesis/devutilities": "^1.10",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "tightenco/duster": "^3.0",
        "tomasvotruba/cognitive-complexity": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "EncoreDigitalGroup\\Heimdall\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "PHPGenesis\\Common\\Composer\\Scripts::postAutoloadDump"
        ],
        "test": "vendor/bin/pest --parallel"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "class": "EncoreDigitalGroup\\Heimdall\\HeimdallPlugin"
    }
}
